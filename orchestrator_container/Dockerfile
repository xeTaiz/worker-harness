FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    openssh-client \
    iproute2 \
    procps \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN id -u worker-harness >/dev/null 2>&1 || useradd -m worker-harness

# Tailscale userspace + daemon
RUN curl -fsSL https://tailscale.com/install.sh | sh

WORKDIR /app

COPY pyproject.toml /app/pyproject.toml
COPY src /app/src
RUN pip install --no-cache-dir .

# Bake orchestrator SSH keypair into image (generated by `just build`).
COPY orchestrator_container/ssh/orchestrator_ed25519 /opt/worker-harness/ssh/orchestrator_ed25519
COPY orchestrator_container/ssh/orchestrator_ed25519.pub /opt/worker-harness/ssh/orchestrator_ed25519.pub
RUN chmod 600 /opt/worker-harness/ssh/orchestrator_ed25519 \
    && chmod 644 /opt/worker-harness/ssh/orchestrator_ed25519.pub
ENV SSH_KEY_PATH=/opt/worker-harness/ssh/orchestrator_ed25519

COPY orchestrator_container/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
