Bootstrap: docker
From: nvcr.io/nvidia/cuda:12.6.3-cudnn-runtime-ubuntu24.04

%labels
    Maintainer worker-harness
    Description "Worker Harness worker image (Tailscale SSH-only)"

%environment
    export DEBIAN_FRONTEND=noninteractive

%files
    worker_container/requirements.txt /requirements.txt
    worker_container/worker_daemon.py /worker_daemon.py
    worker_container/entrypoint.sh /entrypoint.sh
    worker_container/wh-cuda-env /wh-cuda-env
    worker_container/CUDA_ENV_GUIDE.md /opt/wh/CUDA_ENV_GUIDE.md

%post
    set -eux

    rm -f /etc/apt/sources.list.d/*nvidia* /etc/apt/sources.list.d/cuda* 2>/dev/null || true
    find /etc/apt/sources.list.d -type f -name '*.list' -exec sed -i '/developer\.download\.nvidia\.com/d' {} + 2>/dev/null || true

    apt-get update -o Acquire::Retries=5
    apt-get install -y \
        openssh-client \
        tmux \
        git \
        curl \
        wget \
        vim \
        jq \
        python3 \
        python3-pip \
        iproute2 \
        build-essential \
        cmake \
        ninja-build \
        pkg-config \
        file \
        ccache

    ln -sf /usr/bin/python3 /usr/bin/python

    if ! id -u worker-harness >/dev/null 2>&1; then
        useradd -m worker-harness
    fi

    curl -fsSL https://tailscale.com/install.sh | sh

    pip3 install --break-system-packages uv
    pip3 install --break-system-packages -r /requirements.txt

    chmod +x /entrypoint.sh
    chmod +x /wh-cuda-env
    ln -sf /wh-cuda-env /usr/local/bin/wh-cuda-env

%runscript
    exec /entrypoint.sh "$@"

%startscript
    exec /entrypoint.sh "$@"

%help
    Worker Harness worker container for Singularity/Apptainer.
    Uses Tailscale userspace networking and Tailscale SSH for orchestrator control.
